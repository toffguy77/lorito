<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  CloudKit entitlement for Lorito (private database sync of user data).

  NOT wired into project.yml yet: enabling iCloud requires an Apple Developer
  team + the iCloud capability on the app target, and signing. Until then the
  app runs local-first (PersistenceConfig.cloudKitEnabled == false). To enable:
  add `entitlements` + `CODE_SIGN_ENTITLEMENTS` to the Lorito target in
  project.yml, enable the iCloud/CloudKit capability, and set
  cloudKitEnabled = true. See CLAUDE.md.
-->
<plist version="1.0">
<dict>
    <key>com.apple.developer.icloud-container-identifiers</key>
    <array>
        <string>iCloud.com.toffguy.lorito</string>
    </array>
    <key>com.apple.developer.icloud-services</key>
    <array>
        <string>CloudKit</string>
    </array>
    <key>com.apple.developer.ubiquity-kvstore-identifier</key>
    <string>$(TeamIdentifierPrefix)com.toffguy.lorito</string>
</dict>
</plist>
