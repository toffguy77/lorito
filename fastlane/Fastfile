default_platform(:ios)

# App Store Connect API key from env (base64-encoded .p8 content).
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
    issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
    key_content: ENV["APP_STORE_CONNECT_API_KEY"],
    is_key_content_base64: true,
  )
end

# xcodebuild auth args so -allowProvisioningUpdates can manage signing via the key.
def signing_xcargs
  "-allowProvisioningUpdates " \
  "-authenticationKeyPath #{ENV['ASC_KEY_PATH']} " \
  "-authenticationKeyID #{ENV['APP_STORE_CONNECT_KEY_ID']} " \
  "-authenticationKeyIssuerID #{ENV['APP_STORE_CONNECT_ISSUER_ID']}"
end

platform :ios do
  desc "Archive and export an App Store IPA (manual signing with existing dist cert)"
  lane :build do
    key = asc_api_key
    get_provisioning_profile(
      api_key: key,
      app_identifier: "com.toffguy.lorito",
      output_path: "build",
      filename: "lorito_appstore.mobileprovision",
    )
    profile_name = lane_context[SharedValues::SIGH_NAME]
    UI.message("Using profile: #{profile_name}")
    build_app(
      project: "Lorito.xcodeproj",
      scheme: "Lorito",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build/ipa",
      output_name: "Lorito.ipa",
      clean: true,
      xcargs: signing_xcargs,
      export_options: {
        signingStyle: "manual",
        teamID: "3GWRDGA8B7",
        provisioningProfiles: { "com.toffguy.lorito" => profile_name },
      },
    )
  end

  desc "Upload the built IPA to TestFlight (no external distribution)"
  lane :upload do
    upload_to_testflight(
      api_key: asc_api_key,
      ipa: "build/ipa/Lorito.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external: false,
    )
  end

  desc "CI: import signing assets, build, upload to TestFlight, submit for review"
  lane :ci_release do
    setup_ci
    import_certificate(
      certificate_path: "fastlane/certificate.p12",
      certificate_password: ENV["DISTRIBUTION_CERTIFICATE_PASSWORD"],
      keychain_name: "fastlane_tmp_keychain",
      keychain_password: "",
    )
    build  # archives (automatic) + downloads the App Store profile + manual export
    upload_to_testflight(
      api_key: asc_api_key,
      ipa: "build/ipa/Lorito.ipa",
      skip_waiting_for_build_processing: false,
      wait_for_uploaded_build: true,
      distribute_external: false,
    )
    deliver(
      api_key: asc_api_key,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      skip_binary_upload: true,
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false,
      submission_information: { add_id_info_uses_idfa: false },
    )
  end

  desc "Deliver metadata + screenshots and submit the version for review"
  lane :submit do
    deliver(
      api_key: asc_api_key,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      skip_binary_upload: true,
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false,
      submission_information: { add_id_info_uses_idfa: false },
    )
  end
end
